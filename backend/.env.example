# Copy this file to .env and adjust as needed.
# Flask picks these up automatically via python-dotenv if present.

# Optional — override the default HuggingFace model IDs
# DEEPTECTION_VIDEO_MODEL=prithivMLmods/Deep-Fake-Detector-Model
# DEEPTECTION_AUDIO_MODEL=MelodyMachine/Deepfake-audio-detection-V2

# Secret (only matters if sessions are added later)
DEEPTECTION_SECRET=change-me-in-production

# Comma-separated CORS origins (frontend dev server by default)
DEEPTECTION_CORS=http://localhost:5173,http://127.0.0.1:5173

# Port for local run (HF Spaces uses 7860 by default)
PORT=5000
